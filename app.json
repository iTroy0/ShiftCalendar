{
  "expo": {
    "name": "ShiftCalendar",
    "slug": "ShiftCalendar",
    "version": "2.4.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "shiftcalendar",
    "author": "Troy",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "CSV File",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "public.comma-separated-values-text",
              "public.plain-text"
            ]
          },
          {
            "CFBundleTypeName": "JSON Backup",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "public.json",
              "public.data"
            ]
          }
        ]
      }
    },
    "android": {
      "versionCode": 7,
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "navigationBarColor": "transparent",
      "navigationBarHidden": true,
      "package": "com.itroy0.ShiftCalendar",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "content",
              "mimeType": "text/csv"
            },
            {
              "scheme": "content",
              "mimeType": "text/comma-separated-values"
            },
            {
              "scheme": "content",
              "mimeType": "text/plain"
            },
            {
              "scheme": "content",
              "mimeType": "application/json"
            },
            {
              "scheme": "file",
              "mimeType": "text/csv"
            },
            {
              "scheme": "file",
              "mimeType": "text/comma-separated-values"
            },
            {
              "scheme": "file",
              "mimeType": "text/plain"
            },
            {
              "scheme": "file",
              "mimeType": "application/json"
            },
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-notifications",
      ["react-native-android-widget", {
        "widgets": [
          {
            "name": "ShiftWeek",
            "label": "Shift Calendar - Week",
            "minWidth": "320dp",
            "minHeight": "110dp",
            "targetCellWidth": 5,
            "targetCellHeight": 2,
            "description": "Shows your shifts for the current week",
            "updatePeriodMillis": 1800000
          }
        ]
      }]
    ],
    "extra": {
      "eas": {
        "projectId": "6d1188e5-bed3-45e9-82ec-4fb2f5856a1e"
      }
    }
  }
}
